# CollabCode — Environment Variables
# Copy this file to .env and fill in your values

# ── Database ──────────────────────────────────────────────────────────
# Local Docker:
DATABASE_URL=postgresql+asyncpg://collabcode:collabcode_dev_pass@postgres:5432/collabcode
# Production (Neon):
# DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-1.aws.neon.tech/neondb?ssl=require

# ── Redis ─────────────────────────────────────────────────────────────
# Local Docker:
REDIS_URL=redis://:redis_dev_pass@redis:6379/0
# Production (Upstash):
# REDIS_URL=redis://default:password@us1-xxx.upstash.io:6379

# ── Security ──────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_random_32_char_string
TOKEN_EXPIRE_MINUTES=60

# ── CORS (comma separated list of allowed frontend URLs) ──────────────
# Local:
# CORS_ORIGINS=["http://localhost:5173"]
# Production:
# CORS_ORIGINS=["https://your-app.vercel.app"]

# ── URLs ──────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
# Production:
# FRONTEND_URL=https://your-app.vercel.app

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/api/v1/auth/oauth/google/callback
# Production:
# GOOGLE_REDIRECT_URI=https://your-backend.onrender.com/api/v1/auth/oauth/google/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:5173/api/v1/auth/oauth/github/callback
# Production:
# GITHUB_REDIRECT_URI=https://your-backend.onrender.com/api/v1/auth/oauth/github/callback

# ── Docker local only ─────────────────────────────────────────────────
POSTGRES_USER=collabcode
POSTGRES_PASSWORD=collabcode_dev_pass
POSTGRES_DB=collabcode
REDIS_PASSWORD=redis_dev_pass
